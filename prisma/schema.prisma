generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Roles {
  ADMIN
  CUSTOMER
  FARMER
  VENDOR
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  name       String?
  password   String
  role       Roles
  is_active  Boolean @default(false)
  last_seen  DateTime
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  features Features[]
}


model Features {
  id  String @id @default(uuid())
  name String @unique
  url String @unique
  addedby String
  added_by User @relation(fields: [addedby], references: [id])
  roles Roles[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}